{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/whatsapp/health",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/health/scale-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/embaixadores",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/process-notifications",
      "schedule": "0 * * * *"
    }
  ]
}
